# BestByte ESG Vision — Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase (local Docker defaults — no changes needed for local dev) ──────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SB38

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
# JWKS URL format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# Leave blank if using Supabase auth fallback during local dev
# (backend falls back to SUPABASE_JWT_SECRET when CLERK_JWKS_URL is not set)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Leave blank to disable AI report generation (returns 501 without it)
GEMINI_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
